#!/usr/bin/env python3
"""SARFStack Interactive Setup Wizard — bin/start
Run directly in your terminal: ! bin/start
"""

import os
import re
import sys
import shutil
from pathlib import Path

# ── Paths ──────────────────────────────────────────────────────────────────
REPO       = Path(__file__).resolve().parent.parent
PRIVATE    = REPO / "private" / "memory"
WORKSPACES = PRIVATE / "workspaces"
ORG_DIR    = PRIVATE / "organization"

# ── ANSI ───────────────────────────────────────────────────────────────────
R  = "\033[0m"   # reset
B  = "\033[1m"   # bold
D  = "\033[2m"   # dim
GR = "\033[32m"  # green
YL = "\033[33m"  # yellow
CY = "\033[36m"  # cyan
RD = "\033[31m"  # red
BL = "\033[34m"  # blue
MG = "\033[35m"  # magenta

TODO_RE = re.compile(r'\[TODO(?::\s*([^\]]*))?\]')

# ── Logo ───────────────────────────────────────────────────────────────────
LOGO = f"""{CY}{B}
  ____    _    ____  _____
 / ___|  / \\  |  _ \\|  ___|
 \\___ \\ / _ \\ | |_) | |_
  ___) / ___ \\|  _ <|  _|
 |____/_/   \\_\\_| \\_\\_|
{R}{D}         S t a c k{R}   {B}Setup Wizard{R}
"""

# ── Embedded templates ─────────────────────────────────────────────────────
