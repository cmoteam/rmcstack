#!/usr/bin/env python3
"""bin/set-brand — fill TODO fields in private/memory/organization/brand-guidelines.md"""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from _fill_todos import ensure_from_template, fill_todos  # noqa: E402

REPO = Path(__file__).resolve().parent.parent
ORG_DIR = REPO / "private" / "memory" / "organization"
ORG_TEMPLATE = REPO / "templates" / "memory" / "organization"
TARGET = ORG_DIR / "brand-guidelines.md"


def main():
    ensure_from_template(ORG_DIR, ORG_TEMPLATE)
    fill_todos(
        [TARGET],
        header="brand-guidelines.md",
        next_step="/listen team-workspace で workspace 情報を入力",
    )


if __name__ == "__main__":
    main()
