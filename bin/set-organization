#!/usr/bin/env python3
"""bin/set-organization — fill TODO fields in private/memory/organization/organization-overview.md"""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from _fill_todos import ensure_from_template, fill_todos  # noqa: E402

REPO = Path(__file__).resolve().parent.parent
ORG_DIR = REPO / "private" / "memory" / "organization"
ORG_TEMPLATE = REPO / "templates" / "memory" / "organization"
TARGET = ORG_DIR / "organization-overview.md"


def main():
    ensure_from_template(ORG_DIR, ORG_TEMPLATE)
    fill_todos(
        [TARGET],
        header=f"organization-overview.md",
        next_step="bin/set-brand でブランドガイドラインを入力",
    )


if __name__ == "__main__":
    main()
