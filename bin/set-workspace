#!/usr/bin/env python3
"""bin/set-workspace — fill TODO fields in private/memory/workspaces/active/profile/*.md"""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from _fill_todos import fill_todos  # noqa: E402

REPO = Path(__file__).resolve().parent.parent
PROFILE = REPO / "private" / "memory" / "workspaces" / "active" / "profile"
FILES = ["business-overview.md", "icp.md", "positioning.md", "competitors.md"]


def main():
    if not PROFILE.exists() or not PROFILE.is_dir():
        print(f"エラー: {PROFILE} が見つかりません。先に /workspace new <slug> を実行してください。")
        sys.exit(1)

    active = REPO / "private" / "memory" / "workspaces" / "active"
    slug = "(unknown)"
    if active.is_symlink():
        slug = active.readlink().name if hasattr(active, "readlink") else active.resolve().name

    fill_todos(
        [PROFILE / f for f in FILES],
        header=f"アクティブ workspace: {slug}",
        next_step="/listen customer で Customer Sync を埋め、その後 /next で次の一歩を確認",
    )


if __name__ == "__main__":
    main()
